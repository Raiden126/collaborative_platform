{
  "name": "collaborative-workflow-builder",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-grade collaborative workflow automation platform (Vue 3 + NestJS).",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:backend": "pnpm --filter @cwb/backend run start:dev",
    "dev:frontend": "pnpm --filter @cwb/frontend run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm -r run test:e2e",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "prisma:migrate": "pnpm --filter @cwb/backend run prisma:migrate",
    "prisma:seed": "pnpm --filter @cwb/backend run prisma:seed"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
